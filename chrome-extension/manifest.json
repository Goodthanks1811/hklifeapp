{
  "manifest_version": 3,
  "name": "HK Life",
  "short_name": "HK Life",
  "version": "1.0.0",
  "description": "Your Life section — tasks, quick add, and categories from Notion.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "HK Life"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.notion.com/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
